{
  "name": "react-native-apptext",
  "version": "4.2.0",
  "description": "A themeable text component for React Native with typography and responsive scaling",
  "readme": "README.md",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:cjs && npm run build:esm",
    "build:cjs": "tsc --module commonjs --outDir dist/cjs",
    "build:esm": "tsc --module esnext --outDir dist/esm",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "lint": "eslint 'src/**/*.{ts,tsx}' --fix"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Ganesh1110/react-native-apptext.git"
  },
  "keywords": [
    "react-native",
    "react-native-text",
    "react-native-typography",
    "react-native-ui",
    "react-native-components",
    "react-native-design-system",
    "react-native-responsive",
    "react-native-theme",
    "react-native-rtl",
    "react-native-i18n",
    "typography",
    "responsive-text",
    "font-scaling",
    "theming",
    "design-system",
    "rtl",
    "internationalization",
    "localization"
  ],
  "author": "Ganesh Jayaprakash <ganeshjayaprakash3@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Ganesh1110/react-native-apptext/issues"
  },
  "homepage": "https://github.com/Ganesh1110/react-native-apptext#readme",
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-native": ">=0.60.0"
  },
  "devDependencies": {
    "@babel/core": "7.20.0",
    "@babel/parser": "7.23.0",
    "@babel/plugin-transform-class-properties": "7.27.1",
    "@babel/preset-env": "7.20.0",
    "@babel/preset-react": "7.20.0",
    "@babel/preset-typescript": "7.20.0",
    "@babel/runtime": "7.20.0",
    "@babel/traverse": "7.23.0",
    "@react-native/eslint-config": "0.72.2",
    "@react-native/metro-config": "0.72.11",
    "@testing-library/jest-native": "5.4.3",
    "@testing-library/react-native": "13.3.3",
    "@tsconfig/react-native": "3.0.0",
    "@types/jest": "29.2.1",
    "@types/react": "18.0.24",
    "@types/react-test-renderer": "18.0.0",
    "babel-jest": "29.2.1",
    "eslint": "8.19.0",
    "glob": "10.3.0",
    "jest": "29.2.1",
    "metro-react-native-babel-preset": "0.77.0",
    "prettier": "2.4.1",
    "react": "18.2.0",
    "react-native": "0.72.6",
    "react-test-renderer": "18.2.0",
    "typescript": "4.8.4"
  }
}
