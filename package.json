{
  "name": "react-native-apptext",
  "version": "4.2.0",
  "description": "A themeable text component for React Native with typography and responsive scaling",
  "readme": "README.md",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:cjs && npm run build:esm",
    "build:cjs": "tsc --module commonjs --outDir dist/cjs",
    "build:esm": "tsc --module esnext --outDir dist/esm",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "lint": "eslint 'src/**/*.{ts,tsx}' --fix"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Ganesh1110/react-native-apptext.git"
  },
  "keywords": [
    "react-native",
    "react-native-text",
    "react-native-typography",
    "react-native-ui",
    "react-native-components",
    "react-native-design-system",
    "react-native-responsive",
    "react-native-theme",
    "react-native-rtl",
    "react-native-i18n",
    "typography",
    "responsive-text",
    "font-scaling",
    "theming",
    "design-system",
    "rtl",
    "internationalization",
    "localization"
  ],
  "author": "Ganesh Jayaprakash <ganeshjayaprakash3@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Ganesh1110/react-native-apptext/issues"
  },
  "homepage": "https://github.com/Ganesh1110/react-native-apptext#readme",
  "engines": {
    "node": ">=16"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Ganesh1110"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-native": ">=0.60.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/plugin-transform-class-properties": "^7.27.1",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-react": "^7.26.0",
    "@babel/preset-typescript": "^7.26.0",
    "@babel/runtime": "^7.26.0",
    "@tsconfig/react-native": "^3.0.2",
    "@types/jest": "^29.5.14",
    "@types/react": "^18.3.12",
    "glob": "^10.4.5",
    "jest": "^29.7.0",
    "react": "^18.3.1",
    "react-native": "^0.76.0",
    "typescript": "^5.6.3"
  }
}
