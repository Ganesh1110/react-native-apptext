{
  "name": "react-native-text-kit",
  "version": "4.5.0",
  "description": "Production-grade Typography, i18n, animations, RTL, plugin system, and developer tools for React Native",
  "readme": "README.md",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "bin": {
    "react-native-text-kit": "dist/src/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./reanimated": {
      "import": "./dist/src/reanimated.js",
      "require": "./dist/src/reanimated.js",
      "types": "./dist/src/reanimated.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "build:reanimated": "tsc --project tsconfig.reanimated.json",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "lint": "eslint 'src/**/*.{ts,tsx}' --fix"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Ganesh1110/react-native-text-kit.git"
  },
  "keywords": [
    "react-native",
    "text",
    "typography",
    "i18n",
    "localization",
    "l10n",
    "internationalization",
    "react-native-text",
    "react-native-typography",
    "react-native-i18n",
    "react-native-localization",
    "react-native-rtl",
    "react-native-animation",
    "rtl",
    "right-to-left",
    "animated-text",
    "text-animation",
    "typewriter",
    "material-design",
    "material-design-3",
    "md3",
    "responsive-text",
    "font-scaling",
    "design-system",
    "multilingual",
    "arabic",
    "translation",
    "icu",
    "messageformat",
    "locale",
    "accessibility",
    "text-kit",
    "react-native-ui",
    "react-native-components"
  ],
  "author": "Ganesh Jayaprakash <ganeshjayaprakash3@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Ganesh1110/react-native-text-kit/issues"
  },
  "homepage": "https://github.com/Ganesh1110/react-native-text-kit#readme",
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-native": ">=0.60.0"
  },
  "peerDependenciesMeta": {
    "react-native-reanimated": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/parser": "^7.23.0",
    "@babel/plugin-transform-class-properties": "^7.27.1",
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/traverse": "^7.23.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.3.0",
    "@types/react-native": "^0.73.0",
    "glob": "^10.3.0",
    "jest": "^30.2.0",
    "metro-react-native-babel-preset": "^0.77.0",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-native-reanimated": "^4.3.0",
    "react-test-renderer": "^19.2.1",
    "typescript": "^5.6.0"
  }
}
